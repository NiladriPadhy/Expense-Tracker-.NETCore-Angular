<?xml version="1.0" encoding="utf-8"?>
<!--
  Coverlet settings used by `dotnet test - -settings coverlet.runsettings`.
  Restricts collection to Domain + Application assemblies and enforces the
  70% line coverage gate required by T136.
-->
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat code coverage">
        <Configuration>
          <Format>cobertura</Format>
          <Include>[ExpenseTracker.Domain]*,[ExpenseTracker.Application]*</Include>
          <Exclude>[xunit.*]*,[*.Tests]*</Exclude>
          <ExcludeByAttribute>Obsolete,GeneratedCodeAttribute,CompilerGeneratedAttribute</ExcludeByAttribute>
          <SingleHit>false</SingleHit>
          <UseSourceLink>true</UseSourceLink>
          <IncludeTestAssembly>false</IncludeTestAssembly>
          <SkipAutoProps>true</SkipAutoProps>
          <DeterministicReport>false</DeterministicReport>
          <!-- Coverage gate is enforced by scripts/coverage-gate.sh. -->
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
